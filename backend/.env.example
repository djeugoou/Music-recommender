# OpenAI API Configuration
# Required for generating playlists from mood prompts
OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration
# Required for user validation, favorites management, and recommendation history.
# For backend operations, a Service Role key is preferred for admin operations,
# but an Anon key can also be used depending on RLS setups.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
