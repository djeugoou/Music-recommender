# Supabase Client Configuration
# Required for user authentication, fetching favorites, and recommendation history from the client.
VITE_SUPABASE_URL=your_supabase_project_url_here

# Either VITE_SUPABASE_ANON_KEY or VITE_SUPABASE_PUBLISHABLE_KEY is required.
# They represent the same public client-side key.
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
